    {
      "name": "2e8a4922",
      "displayName": "dim_products",
      "queryLines": [
        "-- Revenue trends: total revenue by category\r\n",
        "SELECT \r\n",
        "  category,\r\n",
        "  SUM(total_revenue) AS total_revenue\r\n",
        "FROM prod.gold.dim_products\r\n",
        "GROUP BY category\r\n",
        "ORDER BY total_revenue DESC;\r\n",
        "\r\n",
        "-- Top-performing categories: ranked by total revenue\r\n",
        "SELECT \r\n",
        "  category,\r\n",
        "  SUM(total_revenue) AS total_revenue,\r\n",
        "  SUM(total_qty_sold) AS total_qty_sold\r\n",
        "FROM prod.gold.dim_products\r\n",
        "GROUP BY category\r\n",
        "ORDER BY total_revenue DESC\r\n",
        "LIMIT 10;\r\n",
        "\r\n",
        "-- Customer segmentation: Not available in dim_products table\r\n",
        "-- (No customer data in prod.gold.dim_products)"
      ]
    }
